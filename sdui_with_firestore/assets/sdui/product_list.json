{
  "type": "screen",
  "appBar": {
    "title": "Produtos",
    "backgroundColor": "primary"
  },
  "body": {
    "type": "column",
    "children": [
      {
        "type": "list",
        "source": "products",
        "item": {
          "type": "card",
          "action": {
            "type": "openProduct"
          },
          "children": [
            {
              "type": "image",
              "src": "${images[0]}",
              "width": 64,
              "height": 64,
              "fit": "cover"
            },
            {
              "type": "text",
              "text": "${title}"
            },
            {
              "type": "text",
              "text": "R$ ${price}"
            }
          ]
        }
      }
    ]
  },
  "footer": {
    "type": "text",
    "text": "Produtos carregados via SDUI"
  }
}
